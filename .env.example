# Copy to .env and fill in. Get endpoint + key from Azure Portal or Foundry.

# Resource URL (not the /api/projects/... page — or we auto-fix that for services.ai.azure.com)
AZURE_OPENAI_ENDPOINT=

AZURE_OPENAI_API_KEY=

# Your deployment name in Foundry (example: DeepSeek-V3.2)
AZURE_OPENAI_DEPLOYMENT_NAME=DeepSeek-V3.2

# Optional (default 2024-10-21)
# AZURE_OPENAI_API_VERSION=
